APIFY_TOKEN=your_token_here
APIFY_MEMORY_MB=2048
HENRIK_API_KEY=your_henrikdev_key_here
PORT=3000
# Comma-separated API keys — required even for local development.
API_KEYS=key-alice,key-bob
# Comma-separated Riot IDs to track. Quote values because # starts a comment in .env files.
TRACKED_USERNAMES="Spider31415#6921"
# Enable built-in automatic snapshot refresh inside the API process.
ENABLE_AUTO_REFRESH=true
# Refresh cadence for the built-in scheduler and nextRefreshAt calculation.
REFRESH_INTERVAL_HOURS=48
