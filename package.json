{
  "name": "valorant-stats-api",
  "version": "2.1.1",
  "description": "Valorant stats API using Apify Playwright scraper",
  "keywords": [
    "valorant",
    "api",
    "stats",
    "tracker-gg",
    "apify",
    "express",
    "self-hosted"
  ],
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "refresh:snapshots": "node src/refreshTrackedUsers.js",
    "refresh:profiles": "node src/refreshHenrikProfiles.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "clearMocks": true
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.22.1"
  },
  "overrides": {
    "path-to-regexp": "0.1.13"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AniketRaj314/valorant-stats-api.git"
  },
  "homepage": "https://github.com/AniketRaj314/valorant-stats-api#readme",
  "bugs": {
    "url": "https://github.com/AniketRaj314/valorant-stats-api/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "jest": "^30.2.0",
    "supertest": "^7.2.2"
  }
}
